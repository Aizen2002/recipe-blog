<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>
            About | RecipeHub
        </title>
        <link rel="stylesheet" href="/styles/main.css">
    </head>

    <body>
        <div class="page-wrapper">
            <%- include("partials/header.ejs") %>
                <main>
                    <!-- HERO SECTION -->
                    <section class="about-hero">
                        <h1>
                            About RecipeHub 🍳
                        </h1>
                        <p>
                            Bringing homemade recipes together
                            in one delicious place.
                        </p>
                    </section>
                    <!-- ABOUT CONTENT -->
                    <section class="about-container">
                        <!-- STORY -->
                        <div class="about-card">
                            <h2>
                                Our Story
                            </h2>
                            <p>
                                RecipeHub was created to provide a
                                simple and enjoyable platform where
                                food lovers can create, explore,
                                and manage their favorite recipes.

                                Whether it’s a quick breakfast,
                                comforting dinner, or sweet dessert,
                                RecipeHub helps make cooking more
                                organized and inspiring.
                            </p>
                        </div>
                        <!-- FEATURES -->
                        <div class="about-card">
                            <h2>
                                What You Can Do
                            </h2>
                            <ul>
                                <li>
                                    🍽 Create and share your own recipes
                                </li>
                                <li>
                                    📖 Explore delicious homemade meals
                                </li>
                                <li>
                                    ✏️ Edit and manage your recipes easily
                                </li>
                                <li>
                                    🗑 Delete recipes anytime
                                </li>
                                <li>
                                    🏷 Organize recipes by meal and course
                                </li>
                            </ul>
                        </div>
                        <!-- GOAL -->
                        <div class="about-card">
                            <h2>
                                Our Goal
                            </h2>
                            <p>
                                Our goal is to make cooking more
                                accessible and enjoyable by building
                                a clean and user-friendly recipe
                                platform.

                                RecipeHub focuses on simplicity,
                                creativity, and a great browsing
                                experience for every user.
                            </p>
                        </div>
                    </section>
                </main>
                <%- include("partials/footer.ejs") %>
        </div>
    </body>
</html>